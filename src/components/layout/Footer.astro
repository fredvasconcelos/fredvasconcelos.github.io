---
import { getCurrentLocale } from '../../i18n/utils';
import { getSiteConfig } from '../../i18n/site';

const currentLocale = getCurrentLocale(Astro.url.pathname);
const siteConfig = getSiteConfig(currentLocale);

const footer = siteConfig.footer;
const currentYear = new Date().getFullYear();

const baseUrl = import.meta.env.BASE_URL;

const withBasePath = (path: string) => {
  if (path.startsWith('http://') || path.startsWith('https://') || path.startsWith('mailto:')) {
    return path;
  }

  const cleanBase = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
  const cleanPath = path.replace(/^\//, '');

  return `${cleanBase}${cleanPath}`;
};
---

<footer class="border-t border-white/10 bg-slate-950/80">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr_1fr]">
      <div>
        <a
          href={withBasePath(siteConfig.nav[0].href)}
          class="inline-flex items-center gap-3"
          aria-label={footer.homeAriaLabel}
        >
          <div
            class="flex h-10 w-10 items-center justify-center rounded-2xl border border-cyan-300/30 bg-cyan-300/10 text-sm font-bold text-cyan-200"
          >
            FV
          </div>

          <div class="leading-tight">
            <p class="text-sm font-semibold text-white">
              {siteConfig.name}
            </p>

            <p class="text-xs text-slate-400">
              {siteConfig.title}
            </p>
          </div>
        </a>

        <p class="mt-5 max-w-md text-sm leading-7 text-slate-400">
          {siteConfig.description}
        </p>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-300">
          {footer.navigationTitle}
        </h2>

        <nav class="mt-5 grid gap-3" aria-label={footer.navigationAriaLabel}>
          {
            siteConfig.nav.map((item) => (
              <a
                href={withBasePath(item.href)}
                class="text-sm text-slate-400 transition hover:text-cyan-200"
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-300">
          {footer.contactTitle}
        </h2>

        <div class="mt-5 grid gap-3">
          <a
            href={siteConfig.links.github}
            target="_blank"
            rel="noreferrer"
            class="text-sm text-slate-400 transition hover:text-cyan-200"
          >
            GitHub
          </a>

          <a
            href={siteConfig.links.linkedin}
            target="_blank"
            rel="noreferrer"
            class="text-sm text-slate-400 transition hover:text-cyan-200"
          >
            LinkedIn
          </a>

          <a
            href={siteConfig.links.email}
            class="text-sm text-slate-400 transition hover:text-cyan-200"
          >
            Email
          </a>
        </div>
      </div>
    </div>

    <div
      class="mt-10 flex flex-col gap-4 border-t border-white/10 pt-6 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>
        © {currentYear} {siteConfig.name}. {footer.copyrightPrefix}
      </p>

      <p>
        {footer.builtWith}
      </p>
    </div>
  </div>
</footer>