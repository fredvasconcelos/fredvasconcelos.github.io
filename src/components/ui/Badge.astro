---
interface Props {
  variant?: 'default' | 'soft' | 'outline';
  class?: string;
}

const {
  variant = 'default',
  class: className = '',
} = Astro.props;

const variants = {
  default: 'bg-cyan-300 text-slate-950',
  soft: 'bg-cyan-300/10 text-cyan-200 ring-1 ring-cyan-300/20',
  outline: 'border border-white/10 text-slate-300',
};
---

<span
  class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ${variants[variant]} ${className}`}
>
  <slot />
</span>