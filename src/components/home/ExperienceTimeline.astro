---
import Container from '../ui/Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import Badge from '../ui/Badge.astro';

import { getCurrentLocale } from '../../i18n/utils';
import { getSiteConfig } from '../../i18n/site';

const currentLocale = getCurrentLocale(Astro.url.pathname);
const siteConfig = getSiteConfig(currentLocale);

const experience = siteConfig.experience;
---

<section id="experiencia" class="relative border-t border-white/10 py-24 md:py-32">
  <Container>
    <div class="mb-16">
      <SectionTitle
        eyebrow={experience.eyebrow}
        title={experience.title}
        description={experience.description}
      />
    </div>

    <div class="timeline-wrapper relative">
      <div class="space-y-16 md:space-y-20">
        {
          experience.items.map((item, index) => {
            const isLeft = index % 2 === 0;

            return (
              <article
                class:list={[
                  'timeline-item relative grid md:grid-cols-2 md:gap-16',
                  isLeft ? 'timeline-from-left' : 'timeline-from-right',
                ]}
              >
                <div
                  aria-hidden="true"
                  class="timeline-dot absolute left-5 top-8 z-20 h-4 w-4 -translate-x-1/2 rounded-full border-2 border-cyan-200 bg-slate-950 shadow-[0_0_0_8px_rgba(34,211,238,0.10)] md:left-1/2"
                >
                </div>

                <div
                  class:list={[
                    'timeline-content ml-14 md:ml-0',
                    isLeft ? 'md:pr-12' : 'md:col-start-2 md:pl-12',
                  ]}
                >
                  <div class="timeline-card rounded-[2rem] border border-white/10 bg-white/[0.04] p-6 shadow-xl shadow-slate-950/20 backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-cyan-300/30 hover:bg-white/[0.06] md:p-8">
                    <div class="flex flex-wrap items-center gap-3">
                      <Badge variant="soft">
                        {item.period}
                      </Badge>

                      <span class="text-sm text-slate-500">
                        {item.location}
                      </span>
                    </div>

                    <h3 class="mt-5 text-2xl font-bold text-white">
                      {item.company}
                    </h3>

                    <p class="mt-2 text-sm font-semibold text-cyan-200">
                      {item.role}
                    </p>

                    <p class="mt-5 text-sm leading-7 text-slate-400 md:text-base">
                      {item.description}
                    </p>

                    <ul class="mt-6 space-y-3">
                      {
                        item.highlights.map((highlight) => (
                          <li class="flex gap-3 text-sm leading-6 text-slate-300">
                            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-300"></span>
                            <span>{highlight}</span>
                          </li>
                        ))
                      }
                    </ul>

                    <div class="mt-6 flex flex-wrap gap-2">
                      {
                        item.stack.map((tech) => (
                          <Badge variant="outline">
                            {tech}
                          </Badge>
                        ))
                      }
                    </div>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </Container>
</section>

<script>
  const timelineWrapper = document.querySelector('.timeline-wrapper');
  const timelineItems = document.querySelectorAll('.timeline-item');

  const updateTimeline = () => {
    if (!timelineWrapper) return;

    const rect = timelineWrapper.getBoundingClientRect();
    const windowHeight = window.innerHeight;

    const startPoint = windowHeight * 0.75;
    const endPoint = windowHeight * 0.25;

    const totalDistance = rect.height + startPoint - endPoint;
    const currentDistance = startPoint - rect.top;

    const progress = Math.min(Math.max(currentDistance / totalDistance, 0), 1);
    const progressPercent = progress * 100;
    const progressPixels = rect.height * progress;

    timelineWrapper.style.setProperty('--timeline-progress', `${progressPercent}%`);

    timelineItems.forEach((item) => {
      const dotPosition = item.offsetTop + 32;
      const shouldBeVisible = progressPixels >= dotPosition - 24;

      item.classList.toggle('timeline-visible', shouldBeVisible);
    });
  };

  updateTimeline();

  window.addEventListener('scroll', updateTimeline, { passive: true });
  window.addEventListener('resize', updateTimeline);
</script>

<style>
  .timeline-wrapper {
    --timeline-progress: 0%;
  }

  .timeline-wrapper::before,
  .timeline-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    left: 1.25rem;
    width: 2px;
    border-radius: 999px;
    z-index: 0;
  }

  .timeline-wrapper::before {
    bottom: 0;
    background: rgba(255, 255, 255, 0.12);
  }

  .timeline-wrapper::after {
    height: var(--timeline-progress);
    background: linear-gradient(
      to bottom,
      rgba(34, 211, 238, 1),
      rgba(34, 211, 238, 0.65),
      rgba(168, 85, 247, 0.45)
    );
    box-shadow: 0 0 24px rgba(34, 211, 238, 0.18);
    transition: height 120ms linear;
  }

  .timeline-item {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 700ms ease,
      transform 700ms ease;
  }

  .timeline-item.timeline-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .timeline-content {
    position: relative;
    z-index: 10;
  }

  .timeline-dot {
    transition:
      background-color 500ms ease,
      border-color 500ms ease,
      box-shadow 500ms ease,
      transform 500ms ease;
  }

  .timeline-visible .timeline-dot {
    border-color: rgb(103, 232, 249);
    background-color: rgb(34, 211, 238);
    box-shadow:
      0 0 0 8px rgba(34, 211, 238, 0.1),
      0 0 28px rgba(34, 211, 238, 0.45);
  }

  @media (min-width: 768px) {
    .timeline-wrapper::before,
    .timeline-wrapper::after {
      left: 50%;
      transform: translateX(-50%);
    }

    .timeline-from-left {
      transform: translateX(-56px);
    }

    .timeline-from-right {
      transform: translateX(56px);
    }

    .timeline-from-left.timeline-visible,
    .timeline-from-right.timeline-visible {
      transform: translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-wrapper::after {
      height: 100%;
      transition: none;
    }

    .timeline-item,
    .timeline-from-left,
    .timeline-from-right {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>