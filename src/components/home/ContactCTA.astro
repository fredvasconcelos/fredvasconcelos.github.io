---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';

import { getCurrentLocale } from '../../i18n/utils';
import { getSiteConfig } from '../../i18n/site';

const currentLocale = getCurrentLocale(Astro.url.pathname);
const siteConfig = getSiteConfig(currentLocale);

const contact = siteConfig.contact;
---

<section id="contato" class="relative border-t border-white/10 py-24 md:py-32">
  <Container>
    <div class="relative overflow-hidden rounded-[2.5rem] border border-white/10 bg-white/[0.04] p-8 shadow-2xl shadow-slate-950/40 backdrop-blur md:p-12 lg:p-16">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-cyan-300/20 blur-3xl"
      >
      </div>

      <div
        aria-hidden="true"
        class="pointer-events-none absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-purple-500/20 blur-3xl"
      >
      </div>

      <div class="relative grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <div class="mb-6 flex flex-wrap gap-3">
            <Badge variant="soft">
              {contact.eyebrow}
            </Badge>

            <Badge variant="outline">
              {contact.secondaryBadge}
            </Badge>
          </div>

          <h2 class="max-w-3xl text-4xl font-bold tracking-tight text-white md:text-6xl">
            {contact.title}
          </h2>

          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
            {contact.description}
          </p>
        </div>

        <div class="rounded-[2rem] border border-white/10 bg-slate-950/60 p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-400">
            {contact.availabilityTitle}
          </p>

          <ul class="mt-5 space-y-4 text-sm leading-6 text-slate-300">
            {
              contact.availabilityItems.map((item) => (
                <li class="flex gap-3">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-300"></span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>

          <div class="mt-8 grid gap-3">
            <Button href={siteConfig.links.email} class="w-full">
              {contact.emailLabel}
            </Button>

            <Button
              href={siteConfig.links.linkedin}
              variant="secondary"
              target="_blank"
              rel="noreferrer"
              class="w-full"
            >
              {contact.linkedinLabel}
            </Button>

            <Button
              href={siteConfig.links.github}
              variant="ghost"
              target="_blank"
              rel="noreferrer"
              class="w-full"
            >
              {contact.githubLabel}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>