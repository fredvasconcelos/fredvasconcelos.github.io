---
import Container from '../ui/Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import Badge from '../ui/Badge.astro';

import { getCurrentLocale } from '../../i18n/utils';
import { getSiteConfig } from '../../i18n/site';

const currentLocale = getCurrentLocale(Astro.url.pathname);
const siteConfig = getSiteConfig(currentLocale);

const technologies = siteConfig.technologies;
---

<section id="tecnologias" class="relative border-t border-white/10 py-24 md:py-32">
  <Container>
    <div class="mb-14">
      <SectionTitle
        eyebrow={technologies.eyebrow}
        title={technologies.title}
        description={technologies.description}
      />
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        technologies.groups.map((group) => (
          <article class="group rounded-[2rem] border border-white/10 bg-white/[0.04] p-6 shadow-xl shadow-slate-950/20 transition hover:-translate-y-1 hover:border-cyan-300/30 hover:bg-white/[0.06]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-300/10 text-cyan-200 ring-1 ring-cyan-300/20">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                class="h-6 w-6"
                aria-hidden="true"
              >
                <path
                  d="M4 7.5C4 6.12 7.58 5 12 5s8 1.12 8 2.5S16.42 10 12 10 4 8.88 4 7.5Z"
                  stroke="currentColor"
                  stroke-width="1.8"
                />
                <path
                  d="M4 7.5v4C4 12.88 7.58 14 12 14s8-1.12 8-2.5v-4"
                  stroke="currentColor"
                  stroke-width="1.8"
                />
                <path
                  d="M4 11.5v4C4 16.88 7.58 18 12 18s8-1.12 8-2.5v-4"
                  stroke="currentColor"
                  stroke-width="1.8"
                />
              </svg>
            </div>

            <h3 class="text-xl font-bold text-white">
              {group.category}
            </h3>

            <p class="mt-3 text-sm leading-7 text-slate-400">
              {group.description}
            </p>

            <div class="mt-6 flex flex-wrap gap-2">
              {
                group.items.map((item) => (
                  <Badge variant="soft">
                    {item}
                  </Badge>
                ))
              }
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</section>