---
import Badge from '../ui/Badge.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  category: string;
  stack: readonly string[];
  date: Date;
  image?: string;
  locale?: string;
  readMoreLabel?: string;
  imageAltPrefix?: string;
  fallbackLabel?: string;
}

const {
  title,
  description,
  href,
  category,
  stack,
  date,
  image,
  locale = 'pt-BR',
  readMoreLabel = 'Ver projeto',
  imageAltPrefix = 'Imagem do projeto',
  fallbackLabel = 'BI Project',
} = Astro.props;

const formattedDate = new Intl.DateTimeFormat(locale, {
  month: 'long',
  year: 'numeric',
}).format(date);
---

<article class="group overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.04] shadow-xl shadow-slate-950/20 transition duration-300 hover:-translate-y-1 hover:border-cyan-300/30 hover:bg-white/[0.06]">
  <a href={href} class="block">
    {
      image ? (
        <div class="aspect-[16/9] overflow-hidden border-b border-white/10 bg-slate-900">
          <img
            src={image}
            alt={`${imageAltPrefix} ${title}`}
            class="h-full w-full object-cover opacity-85 transition duration-500 group-hover:scale-105 group-hover:opacity-100"
            loading="lazy"
            decoding="async"
          />
        </div>
      ) : (
        <div class="flex aspect-[16/9] items-center justify-center border-b border-white/10 bg-gradient-to-br from-cyan-300/10 via-slate-900 to-purple-500/10">
          <span class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-200">
            {fallbackLabel}
          </span>
        </div>
      )
    }

    <div class="p-6 md:p-7">
      <div class="mb-4 flex flex-wrap items-center gap-3">
        <Badge variant="soft">
          {category}
        </Badge>

        <span class="text-xs text-slate-500">
          {formattedDate}
        </span>
      </div>

      <h2 class="text-2xl font-bold tracking-tight text-white transition group-hover:text-cyan-100">
        {title}
      </h2>

      <p class="mt-4 text-sm leading-7 text-slate-400">
        {description}
      </p>

      <div class="mt-6 flex flex-wrap gap-2">
        {
          stack.slice(0, 5).map((item) => (
            <Badge variant="outline">
              {item}
            </Badge>
          ))
        }
      </div>

      <div class="mt-7 inline-flex items-center gap-2 text-sm font-bold text-cyan-200">
        {readMoreLabel}
        <span class="transition group-hover:translate-x-1">→</span>
      </div>
    </div>
  </a>
</article>